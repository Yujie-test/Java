							"parentStyle": false,
							"left": 616,
							"top": 352,
							"width": 256.53662109375,
							"height": 25,
							"text": "TreeMap集合底层的数据结构是一个二叉树"
						},
						{
							"_type": "UMLNoteLinkView",
